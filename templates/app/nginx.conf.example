# Example nginx server block for a PhpServicePlatform project.
# Copy to your nginx sites, adjust server_name / paths / PHP socket, reload.
# The Apache equivalent ships as app/public/.htaccess.

server {
    listen 80;
    server_name example.com;

    # Docroot is app/public ONLY — never the project root (keeps .env, config,
    # src, vendor OUT of the web-served tree).
    root /var/www/{{PROJECT_NAME}}/app/public;
    index index.php;

    # Deny all dotfiles (.env, .git, .htaccess, …) even if placed under root.
    location ~ /\. {
        deny all;
        return 404;
    }

    # Never serve PHP files other than the front controller directly.
    location ~ \.php$ {
        # Only index.php is allowed to execute.
        location = /index.php {
            include fastcgi_params;
            fastcgi_param SCRIPT_FILENAME $document_root/index.php;

            # ── Run-env: everything the project needs to BOOT under FPM ──
            # FPM workers do NOT inherit your shell/`hkm` environment, so pass it here.
            # (`hkm … edge:apply` generates all of this for you, per dev/live.)
            fastcgi_param APP_ENV production;
            # Where persisted tenant data lives (uploads/reports/exports):
            # fastcgi_param HKM_USERDATA_DIR /var/lib/hkm;
            #
            # LIVE — the installed kernel (values from `hkm-config print`):
            # fastcgi_param HKM_KERNEL_HOME     /opt/hkm-kernel;
            # fastcgi_param PSP_PROJECTS_DIR    /opt/hkm-kernel/projects;
            # fastcgi_param PSP_GLOBAL_AUTOLOAD /opt/hkm-kernel/vendor/autoload.php;
            #
            # DEV — against a checkout instead (HKM_DEV_HOME from config.env):
            # fastcgi_param HKM_DEV_HOME        /path/to/checkout;
            # fastcgi_param HKM_KERNEL_HOME     /path/to/checkout;
            # fastcgi_param PSP_GLOBAL_AUTOLOAD /path/to/checkout/vendor/autoload.php;
            # fastcgi_param PSP_PROJECTS_DIR    /path/to/checkout/projects;

            # PHP-FPM pool. On a multi-PHP host use the VERSIONED socket that matches
            # the PHP your project targets (e.g. php8.4-fpm.sock), not the generic one:
            fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        }
        return 404;
    }

    # Front controller: route everything else through index.php.
    location / {
        try_files $uri /index.php$is_args$args;
    }

    # Baseline security headers (SecurityFilters plugin also sets these at runtime).
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    server_tokens off;

    client_max_body_size 25m;
}
