parameters:
    level: 5
    paths:
        - src
        - plugins
        - projects
    scanDirectories:
        - modules
    excludePaths:
        - */vendor/*
        - */__dev__/*
        - projects/*/var/*
        - projects/*/userdata/*
        # Pre-existing bugs (tracked separately, not analysable until fixed):
        #   - MigrateListCommand extends a non-existent AbstractMigrateCommand
        #   - OutboxWriter does not satisfy OutboxPort (missing markDispatched, wrong write() return)
        - src/Commands/Migrate/MigrateListCommand.php
        - plugins/User/Infrastructure/Outbox/OutboxWriter.php
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false

includes:
    - phpstan-baseline.neon
