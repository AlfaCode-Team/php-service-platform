{
    "name": "voting",
    "version": "1.0.0",
    "solves": "voting.management",
    "type": "module",

    "requires": ["database.query"],
    "exposes": [
        "Plugins\\Voting\\API\\Contracts\\VotingServiceContract",
        "Plugins\\Voting\\API\\Contracts\\EditionServiceContract",
        "Plugins\\Voting\\API\\Contracts\\EditionSettingsServiceContract",
        "Plugins\\Voting\\API\\Contracts\\BoostingServiceContract",
        "Plugins\\Voting\\API\\Contracts\\SubscriptionServiceContract"
    ],

    "routes": [
        { "method": "GET",    "path": "/api/voting/editions",                          "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@index" },
        { "method": "POST",   "path": "/api/voting/editions",                          "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@create" },
        { "method": "GET",    "path": "/api/voting/editions/{id}",                     "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@show" },
        { "method": "PUT",    "path": "/api/voting/editions/{id}",                     "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@update" },
        { "method": "POST",   "path": "/api/voting/editions/{id}/activate",            "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@activate" },
        { "method": "POST",   "path": "/api/voting/editions/{id}/close",               "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@close" },
        { "method": "POST",   "path": "/api/voting/editions/{id}/contestants",         "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@addContestant" },
        { "method": "DELETE", "path": "/api/voting/contestants/{id}",                  "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionController@removeContestant" },
        { "method": "GET",    "path": "/api/voting/editions/{id}/contestants",         "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\VotingController@leaderboard" },
        { "method": "POST",   "path": "/api/voting/contestants/{id}/vote",             "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\VotingController@castVote" },
        { "method": "GET",    "path": "/api/voting/editions/{id}/settings",            "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionSettingsController@show" },
        { "method": "PUT",    "path": "/api/voting/editions/{id}/settings",            "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\EditionSettingsController@update" },
        { "method": "POST",   "path": "/api/voting/contestants/{id}/boost",            "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\BoostingController@initiate" },
        { "method": "POST",   "path": "/api/voting/boost/confirm",                     "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\BoostingController@confirm" },
        { "method": "GET",    "path": "/api/voting/editions/{id}/subscription",        "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\SubscriptionController@show" },
        { "method": "POST",   "path": "/api/voting/editions/{id}/subscribe",           "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\SubscriptionController@subscribe" },
        { "method": "POST",   "path": "/api/voting/subscription/confirm",              "handler": "Plugins\\Voting\\Infrastructure\\Http\\Controllers\\SubscriptionController@confirm" }
    ],

    "emits": [
        "voting.vote_cast",
        "voting.contestant_added",
        "voting.boost_confirmed",
        "voting.subscription_upgraded"
    ],
    "listens": [],

    "config": [
        { "key": "VOTING_COOLDOWN_HOURS",            "type": "int",    "required": false },
        { "key": "VOTING_FLUTTERWAVE_SECRET_KEY",    "type": "string", "required": false },
        { "key": "VOTING_FLUTTERWAVE_PUBLIC_KEY",    "type": "string", "required": false },
        { "key": "VOTING_APP_LOGO_URL",              "type": "string", "required": false },
        { "key": "VOTING_HMAC_SECRET",               "type": "string", "required": false },
        { "key": "VOTING_RATE_LIMIT_PER_MINUTE",     "type": "int",    "required": false },
        { "key": "VOTING_RATE_LIMIT_WINDOW_SEC",     "type": "int",    "required": false },
        { "key": "VOTING_PRICE_TIER1_MAX",           "type": "int",    "required": false },
        { "key": "VOTING_PRICE_TIER1_KOBO",          "type": "int",    "required": false },
        { "key": "VOTING_PRICE_TIER2_MAX",           "type": "int",    "required": false },
        { "key": "VOTING_PRICE_TIER2_KOBO",          "type": "int",    "required": false },
        { "key": "VOTING_PRICE_TIER3_KOBO",          "type": "int",    "required": false },
        { "key": "VOTING_FREE_VOTE_ENABLED",         "type": "bool",   "required": false }
    ]
}
