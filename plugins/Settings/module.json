{
    "name": "settings",
    "version": "1.0.0",
    "solves": "tenant.settings",
    "type": "module",

    "requires": ["database.management", "validation.rules"],
    "exposes": ["Plugins\\Settings\\API\\Contracts\\SettingsServiceContract"],

    "routes": [
        { "method": "GET",    "path": "/api/settings/company",      "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@company",           "filters": ["auth"] },
        { "method": "PUT",    "path": "/api/settings/company",      "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@saveCompany",       "filters": ["auth"] },
        { "method": "POST",   "path": "/api/settings/company/logo", "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@uploadCompanyLogo", "filters": ["auth"], "requires": ["storage.local"] },
        { "method": "DELETE", "path": "/api/settings/company/logo", "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@removeCompanyLogo", "filters": ["auth"], "requires": ["storage.local"] },
        { "method": "GET", "path": "/api/settings/contact",         "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@contact",        "filters": ["auth"] },
        { "method": "PUT", "path": "/api/settings/contact",         "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@saveContact",    "filters": ["auth"] },
        { "method": "GET", "path": "/api/settings/email",           "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@email",          "filters": ["auth"] },
        { "method": "PUT", "path": "/api/settings/email",           "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@saveEmail",      "filters": ["auth"] },
        { "method": "GET", "path": "/api/settings/email-providers", "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@emailProviders", "filters": ["auth"] },
        { "method": "PUT", "path": "/api/settings/email-providers", "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@saveEmailProviders", "filters": ["auth"] },
        { "method": "GET", "path": "/api/settings/system",          "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@system",         "filters": ["auth"] },
        { "method": "PUT", "path": "/api/settings/system",          "handler": "Plugins\\Settings\\Infrastructure\\Http\\SettingsController@saveSystem",     "filters": ["auth"] }
    ],

    "emits":   [],
    "listens": [],

    "config": []
}
