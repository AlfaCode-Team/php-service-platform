{
    "name": "task",
    "version": "1.0.0",
    "solves": "task.management",
    "type": "module",

    "requires": ["database.query","view.rendering"],
    "exposes": ["Plugins\\Task\\API\\Contracts\\TaskServiceContract"],

    "routes": [
        { "method": "GET",    "path": "/api/tasks",      "handler": "Plugins\\Task\\Infrastructure\\Http\\TaskController@index"   },
        { "method": "POST",   "path": "/api/tasks",      "handler": "Plugins\\Task\\Infrastructure\\Http\\TaskController@create"  },
        { "method": "GET",    "path": "/api/tasks/{id}", "handler": "Plugins\\Task\\Infrastructure\\Http\\TaskController@show"    },
        { "method": "POST",   "path": "/api/tasks/{id}/complete", "handler": "Plugins\\Task\\Infrastructure\\Http\\TaskController@complete" },
        { "method": "DELETE", "path": "/api/tasks/{id}", "handler": "Plugins\\Task\\Infrastructure\\Http\\TaskController@destroy" }
    ],

    "emits":   ["task.created"],
    "listens": [],

    "config": []
}
 